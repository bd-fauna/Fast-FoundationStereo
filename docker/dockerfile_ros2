# Runtime image for the Fast-FoundationStereo ROS 2 stereo depth pipeline.
#
# Contains: CUDA 12.4, TensorRT 10 (runtime + ONNX parser + C++ headers +
# trtexec), OpenCV, ROS 2 Humble, and the prebuilt ffs_ros workspace
# (ffs_stereo_node + the cpp/ engine-builder tools).
#
# Build from the repo root:
#   docker build --network host -t ffs_ros2 -f docker/dockerfile_ros2 .
#
# Note: this image does NOT ship the Python/PyTorch stack. Export the plugin
# ONNX with docker/dockerfile_cpp (or any python env), then build the TRT
# engine inside THIS image on the deployment GPU so the TensorRT versions and
# GPU architecture match:
#   ros2 run ffs_ros ffs_build_single_engine <model.onnx> <model.engine>

FROM nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

ARG DEBIAN_FRONTEND=noninteractive
ENV TZ=US/Pacific
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# Build tools + OpenCV. TRT itself is installed below from the local 10.11 deb so
# the engine-build TRT version matches docker/dockerfile_cpp exactly. Without a
# pin, apt resolves libnvinfer-dev to TRT 11 which removed
# `IPluginRegistry::getPluginCreator()` used by cpp/src/gwc_volume_plugin.cpp.
RUN apt-get update --fix-missing && \
    apt-get install -y apt-utils build-essential ca-certificates cmake curl git gnupg2 \
      locales lsb-release pkg-config software-properties-common wget \
      libopencv-dev && \
    rm -rf /var/lib/apt/lists/*

# TensorRT 10.11 (same deb as docker/dockerfile_cpp). Engines built here will run
# in this image at deploy time, so versions must match. The CUDA base image's
# public NVIDIA repo serves TRT 11 alongside 10.x and apt would otherwise pull
# the higher version + headers. We temporarily move the public NVIDIA repo lists
# aside so apt only sees the local 10.11 repo for this install.
RUN cd / && wget --quiet https://developer.download.nvidia.com/compute/tensorrt/10.11.0/local_installers/nv-tensorrt-local-repo-ubuntu2204-10.11.0-cuda-12.9_1.0-1_amd64.deb && \
    apt-get install -y ./nv-tensorrt-local-repo-ubuntu2204-10.11.0-cuda-12.9_1.0-1_amd64.deb && \
    cp /var/nv-tensorrt-local-repo-ubuntu2204-10.11.0-cuda-12.9/nv-tensorrt-local-*-keyring.gpg /usr/share/keyrings/ && \
    mkdir -p /tmp/apt-disabled && \
    mv /etc/apt/sources.list.d/cuda-ubuntu2204-x86_64.list /tmp/apt-disabled/ 2>/dev/null || true && \
    mv /etc/apt/sources.list.d/nvidia-ml.list /tmp/apt-disabled/ 2>/dev/null || true && \
    apt-get update && \
    apt-get install -y libnvinfer10 libnvinfer-dev libnvinfer-plugin10 libnvinfer-plugin-dev \
      libnvonnxparsers10 libnvonnxparsers-dev libnvinfer-dispatch10 libnvinfer-bin && \
    mv /tmp/apt-disabled/* /etc/apt/sources.list.d/ 2>/dev/null || true && \
    rmdir /tmp/apt-disabled && \
    rm -f /nv-tensorrt-local-repo-ubuntu2204-10.11.0-cuda-12.9_1.0-1_amd64.deb && \
    rm -rf /var/lib/apt/lists/*

RUN locale-gen en_US en_US.UTF-8 && update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8
ENV LANG=en_US.UTF-8

# ROS 2 Humble (Ubuntu 22.04 / Jammy).
RUN add-apt-repository universe && \
    curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
      -o /usr/share/keyrings/ros-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] http://packages.ros.org/ros2/ubuntu $(. /etc/os-release && echo $UBUNTU_CODENAME) main" \
      > /etc/apt/sources.list.d/ros2.list && \
    apt-get update && \
    apt-get install -y ros-humble-ros-base ros-humble-cv-bridge ros-humble-message-filters \
      ros-humble-image-transport ros-humble-depth-image-proc \
      ros-humble-rosbag2-storage-mcap \
      python3-colcon-common-extensions && \
    rm -rf /var/lib/apt/lists/*

# CUDA SM architectures baked into the cpp/ kernels (cpp/CMakeLists.txt default
# covers Ampere..Hopper). Override for other GPUs, e.g. Jetson Orin: "87".
ARG FFS_CUDA_ARCHS="80;86;89;90"

COPY . /opt/ffs
WORKDIR /opt/ffs/ros2
SHELL ["/bin/bash", "-c"]
RUN source /opt/ros/humble/setup.bash && \
    colcon build --event-handlers console_direct+ \
      --cmake-args -DCMAKE_BUILD_TYPE=Release "-DCMAKE_CUDA_ARCHITECTURES=${FFS_CUDA_ARCHS}"

RUN chmod +x /opt/ffs/docker/ros2_entrypoint.sh
ENTRYPOINT ["/opt/ffs/docker/ros2_entrypoint.sh"]
CMD ["bash"]
